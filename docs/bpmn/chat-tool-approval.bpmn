<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_ChatToolApproval" targetNamespace="https://github.com/Hitek5/tekla-rd-ai-agent/bpmn">
  <bpmn:process id="Process_ChatToolApproval" name="Tekla AI request and tool approval" isExecutable="false">
    <bpmn:startEvent id="Start_UserRequest" name="User submits CAD/RD request">
      <bpmn:outgoing>Flow_Start_To_RAG</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_RetrieveContext" name="Retrieve RAG context">
      <bpmn:incoming>Flow_Start_To_RAG</bpmn:incoming>
      <bpmn:outgoing>Flow_RAG_To_LLM</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CallLLM" name="Ask local LLM for answer or tool plan">
      <bpmn:incoming>Flow_RAG_To_LLM</bpmn:incoming>
      <bpmn:outgoing>Flow_LLM_To_ToolGateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_ToolNeeded" name="Tool call needed?">
      <bpmn:incoming>Flow_LLM_To_ToolGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_NoTool_To_Answer</bpmn:outgoing>
      <bpmn:outgoing>Flow_Tool_To_Policy</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ReturnAnswer" name="Return text answer to engineer">
      <bpmn:incoming>Flow_NoTool_To_Answer</bpmn:incoming>
      <bpmn:outgoing>Flow_Answer_To_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:businessRuleTask id="Task_CheckPolicy" name="Check tool whitelist and risk policy">
      <bpmn:incoming>Flow_Tool_To_Policy</bpmn:incoming>
      <bpmn:outgoing>Flow_Policy_To_MutationGateway</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_Mutating" name="Mutates model?">
      <bpmn:incoming>Flow_Policy_To_MutationGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Read_To_Execute</bpmn:outgoing>
      <bpmn:outgoing>Flow_Mutation_To_Approval</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_Approval" name="Approval token present?">
      <bpmn:incoming>Flow_Mutation_To_Approval</bpmn:incoming>
      <bpmn:outgoing>Flow_Approval_No_To_DryRun</bpmn:outgoing>
      <bpmn:outgoing>Flow_Approval_Yes_To_Execute</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ReturnDryRun" name="Return dry-run plan and request approval">
      <bpmn:incoming>Flow_Approval_No_To_DryRun</bpmn:incoming>
      <bpmn:outgoing>Flow_DryRun_To_Audit</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_ExecuteTeklaTool" name="Execute approved Tekla workstation tool">
      <bpmn:incoming>Flow_Read_To_Execute</bpmn:incoming>
      <bpmn:incoming>Flow_Approval_Yes_To_Execute</bpmn:incoming>
      <bpmn:outgoing>Flow_Execute_To_Audit</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_WriteAudit" name="Write JSONL audit event">
      <bpmn:incoming>Flow_DryRun_To_Audit</bpmn:incoming>
      <bpmn:incoming>Flow_Execute_To_Audit</bpmn:incoming>
      <bpmn:outgoing>Flow_Audit_To_Result</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ReturnToolResult" name="Return result, warning or next action">
      <bpmn:incoming>Flow_Audit_To_Result</bpmn:incoming>
      <bpmn:outgoing>Flow_Result_To_End</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_RequestHandled" name="Request handled">
      <bpmn:incoming>Flow_Answer_To_End</bpmn:incoming>
      <bpmn:incoming>Flow_Result_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_RAG" sourceRef="Start_UserRequest" targetRef="Task_RetrieveContext" />
    <bpmn:sequenceFlow id="Flow_RAG_To_LLM" sourceRef="Task_RetrieveContext" targetRef="Task_CallLLM" />
    <bpmn:sequenceFlow id="Flow_LLM_To_ToolGateway" sourceRef="Task_CallLLM" targetRef="Gateway_ToolNeeded" />
    <bpmn:sequenceFlow id="Flow_NoTool_To_Answer" name="No" sourceRef="Gateway_ToolNeeded" targetRef="Task_ReturnAnswer" />
    <bpmn:sequenceFlow id="Flow_Tool_To_Policy" name="Yes" sourceRef="Gateway_ToolNeeded" targetRef="Task_CheckPolicy" />
    <bpmn:sequenceFlow id="Flow_Answer_To_End" sourceRef="Task_ReturnAnswer" targetRef="End_RequestHandled" />
    <bpmn:sequenceFlow id="Flow_Policy_To_MutationGateway" sourceRef="Task_CheckPolicy" targetRef="Gateway_Mutating" />
    <bpmn:sequenceFlow id="Flow_Read_To_Execute" name="No" sourceRef="Gateway_Mutating" targetRef="Task_ExecuteTeklaTool" />
    <bpmn:sequenceFlow id="Flow_Mutation_To_Approval" name="Yes" sourceRef="Gateway_Mutating" targetRef="Gateway_Approval" />
    <bpmn:sequenceFlow id="Flow_Approval_No_To_DryRun" name="No" sourceRef="Gateway_Approval" targetRef="Task_ReturnDryRun" />
    <bpmn:sequenceFlow id="Flow_Approval_Yes_To_Execute" name="Yes" sourceRef="Gateway_Approval" targetRef="Task_ExecuteTeklaTool" />
    <bpmn:sequenceFlow id="Flow_DryRun_To_Audit" sourceRef="Task_ReturnDryRun" targetRef="Task_WriteAudit" />
    <bpmn:sequenceFlow id="Flow_Execute_To_Audit" sourceRef="Task_ExecuteTeklaTool" targetRef="Task_WriteAudit" />
    <bpmn:sequenceFlow id="Flow_Audit_To_Result" sourceRef="Task_WriteAudit" targetRef="Task_ReturnToolResult" />
    <bpmn:sequenceFlow id="Flow_Result_To_End" sourceRef="Task_ReturnToolResult" targetRef="End_RequestHandled" />
  </bpmn:process>
</bpmn:definitions>

