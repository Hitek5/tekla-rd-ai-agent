# Orchestrator
AGENT_ENV=local
AGENT_HOST=0.0.0.0
AGENT_PORT=8080
AUDIT_LOG_PATH=data/audit/orchestrator.jsonl
APPROVAL_LEDGER_PATH=data/audit/consumed-approvals.log

# OpenAI-compatible local LLM endpoint.
# Ollama native API differs; use Ollama OpenAI-compatible endpoint if enabled,
# or point this at vLLM/SGLang/llama.cpp server.
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_API_KEY=local-dev-key
LLM_MODEL=qwen2.5-coder-7b-instruct-q4
LLM_TIMEOUT_SECONDS=120

# Optional local embeddings (reuse the same OpenAI-compatible server). Leave the
# model blank to stay BM25-only and keep all VRAM for the chat model.
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=

# RAG
RAG_CHUNKS_PATH=data/rag/chunks.jsonl
RAG_TOP_K=5
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=tekla_rd_docs

# Safety
DEFAULT_DRY_RUN=true
REQUIRE_APPROVAL_FOR_MUTATIONS=true
ALLOW_PRODUCTION_MODEL_WRITES=false

# --- Security (set strong values before any pilot; never ship the defaults) ---
# Shared HMAC secret for approval tokens. The SAME value must be exported to the
# C# workstation host as TEKLA_AGENT_APPROVAL_SECRET. Use >= 32 random chars.
# REQUIRED: the orchestrator REFUSES TO START with this placeholder or any other
# well-known default. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
APPROVAL_SECRET=change-me-please-set-a-32-char-secret
APPROVAL_TTL_SECONDS=600
# Bearer key required for all API calls. Empty = auth disabled (local dev only).
API_KEY=
# Stronger, separate key that authorises minting approvals (the human sign-off).
# MUST differ from API_KEY — the orchestrator refuses to start if they are equal
# (otherwise any API client could self-approve mutating tools).
APPROVER_API_KEY=
# Key that HMACs the audit hash chain (tamper evidence against file-only access).
# Empty = reuse APPROVAL_SECRET. Set a dedicated value to decouple the two.
AUDIT_HMAC_KEY=
# Abuse limits.
MAX_REQUEST_BYTES=65536
RATE_LIMIT_PER_MINUTE=60

# Model integrity manifest (SHA-256 per served model file).
MODEL_MANIFEST_PATH=data/models/manifest.json

# Offline mode, enable after models/packages are mirrored.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
